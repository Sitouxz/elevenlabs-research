# ── ElevenLabs Agents ──────────────────────────────────────────────────────────
# Navigation agent (always-on, handles screen transitions & topic selection)
VITE_ELEVENLABS_NAV_AGENT_ID=your_nav_agent_id_here

# QnA agent (active only on Ask Questions screen)
VITE_ELEVENLABS_QNA_AGENT_ID=your_qna_agent_id_here

# ── Akool Avatar ───────────────────────────────────────────────────────────────
# Get keys from https://akool.com/dashboard
VITE_AKOOL_CLIENT_ID=your_akool_client_id_here
VITE_AKOOL_CLIENT_SECRET=your_akool_client_secret_here
VITE_AKOOL_AVATAR_ID=your_avatar_id_here
VITE_AKOOL_VOICE_ID=your_voice_id_here

# ── Optional (Groq vision - retained for future use) ───────────────────────────
# VITE_VISION_API_KEY=your_groq_key
# VITE_VISION_BASE_URL=https://api.groq.com/openai/v1
# VITE_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
