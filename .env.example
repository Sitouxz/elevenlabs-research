# ── Akool Avatar (v4 API + Agora RTC) ─────────────────────────────────────────
# Get keys from https://akool.com/apps/streaming-avatar
VITE_AKOOL_CLIENT_ID=your_akool_client_id_here
VITE_AKOOL_CLIENT_SECRET=your_akool_client_secret_here
# Avatar ID from https://akool.com/apps/upload/avatar (e.g. dvp_Tristan_cloth2_1080P)
VITE_AKOOL_AVATAR_ID=your_avatar_id_here
# Optional: Akool voice ID
VITE_AKOOL_VOICE_ID=your_voice_id_here
# Knowledge Base ID from https://akool.com — feeds Akool's built-in LLM
VITE_AKOOL_KNOWLEDGE_ID=your_knowledge_id_here
# Language code for STT/TTS (default: en)
VITE_AKOOL_LANGUAGE=en
# Optional: LLM provider for fast_dialogue mode (e.g. "openai")
# VITE_AKOOL_LLM_PROVIDER=openai
# Optional: Override the default system prompt (Lumi smart energy guide)
# VITE_AKOOL_SYSTEM_PROMPT=You are Lumi, a friendly AI guide...

# ── ElevenLabs Voice (for fast_dialogue TTS) ───────────────────────────────────
# fast_dialogue mode uses voice_params.elevenlabs_settings for the voice.
# VITE_AKOOL_VOICE_ID is NOT used in fast_dialogue — use these instead.
# Get your ElevenLabs API key from https://elevenlabs.io
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# ElevenLabs voice ID — use a female voice e.g. Rachel=21m00Tcm4TlvDq8ikWAM, Bella=EXAVITQu4vr4xnSDxMaL
VITE_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── FX Chatbot Tutor (custom LLM via Akool retelling mode) ────────────────────
# When all five VITE_FX_* vars are set, Akool runs in retelling mode (mode_type:1)
# and the avatar speaks responses generated by FX instead of Akool's built-in LLM.
# Discover config_id / app_id with:
#   curl -H "Authorization: Bearer <jwt>" \
#     https://fxm-llm.fxwebapps.com/api/config/passphrase/<passphrase>
VITE_FX_BASE_URL=https://fxm-llm.fxwebapps.com
VITE_FX_TOKEN=your_fx_jwt_here
VITE_FX_PASSPHRASE=your_fx_passphrase_here
VITE_FX_CONFIG_ID=1
VITE_FX_APP_ID=1
# Optional: ask FX to compute facial expression hints (slower)
# VITE_FX_USE_EXPRESSION=true
