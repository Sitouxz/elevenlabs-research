# ElevenLabs Agent ID (from your ElevenLabs dashboard)
VITE_ELEVENLABS_AGENT_ID=your_agent_id_here

# Vision API — follows OpenAI chat/completions format with image_url
# Default provider: Groq (free, 30 RPM) — get a key at https://console.groq.com
VITE_VISION_API_KEY=your_groq_api_key_here

# Optional overrides (defaults work with Groq free tier):
# VITE_VISION_BASE_URL=https://api.groq.com/openai/v1
# VITE_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# To use OpenAI instead:
# VITE_VISION_API_KEY=your_openai_key
# VITE_VISION_BASE_URL=https://api.openai.com/v1
# VITE_VISION_MODEL=gpt-4o-mini

# -- Replicate (AI image generation) ------------------------------------
# Server-only token (no VITE_ prefix) — injected by the Vite dev proxy at
# /api/replicate so the key never reaches the browser bundle.
# Get a token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_token_here

# Optional model override. Defaults to black-forest-labs/flux-schnell
# (~3s, ~$0.003/image). Other good options:
#   black-forest-labs/flux-1.1-pro   (slower, higher quality)
#   stability-ai/sdxl                 (classic SDXL)
# VITE_REPLICATE_MODEL=black-forest-labs/flux-schnell
